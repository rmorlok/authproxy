      "title": "Proxy error rate",
      "description": "Share of outbound proxy calls returning 5xx, computed from the duration histogram counter. 4xx responses are intentionally excluded — they're client errors, not service errors, per OTel HTTP semconv.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(authproxy_client_request_duration_seconds_count{authproxy_request_type=\"proxy\", http_response_status_code=~\"5..\"}[1m])) / sum(rate(authproxy_client_request_duration_seconds_count{authproxy_request_type=\"proxy\"}[1m]))",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
