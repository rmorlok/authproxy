          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (http_request_method, http_response_status_code) (rate(authproxy_client_request_duration_seconds_count{authproxy_request_type=\"proxy\"}[1m]))",
