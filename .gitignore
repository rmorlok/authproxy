# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# Don't persist secrets that can be in the .env file
.env

.idea
.DS_Store

.output.txt

tmp

.junie
.yarn
node_modules

# Built UI artifacts — embedded at compile time via //go:embed.
# Only .gitkeep is tracked so a fresh checkout still compiles before
# `vite build` runs; Vite is configured with emptyOutDir:false so the
# committed .gitkeep survives across builds.
ui/*/embed/dist/*
!ui/*/embed/dist/.gitkeep

dev_config/keys/tls

.claude/scheduled_tasks.lock
.codex/config.local.toml
.codex/local/*