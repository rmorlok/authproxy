{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rmorlok/authproxy/refs/heads/main/schema/resources/connectors/schema.json",
  "$defs": {
    "AuthApiKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "placement"],
      "properties": {
        "type": {
          "const": "api-key"
        },
        "placement": {
          "$ref": "#/$defs/ApiKeyPlacement"
        }
      }
    },
    "ConnectorTelemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "propagate_trace_context": {
          "type": "boolean"
        }
      }
    },
    "ApiKeyPlacement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["bearer", "header", "query", "basic"]
        },
        "header_name": {
          "type": "string"
        },
        "prefix": {
          "type": "string"
        },
        "param_name": {
          "type": "string"
        },
        "username_field": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "header" } } },
          "then": { "required": ["header_name"] }
        },
        {
          "if": { "properties": { "type": { "const": "query" } } },
          "then": { "required": ["param_name"] }
        },
        {
          "if": { "properties": { "type": { "const": "basic" } } },
          "then": { "required": ["username_field"] }
        }
      ]
    },
    "AuthNoAuth": {
      "properties": {
        "type": {
          "const": "no-auth"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Probe": {
      "oneOf": [
        {
          "required": ["id", "http"]
        },
        {
          "required": ["id", "proxy_http"]
        }
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "period": {
          "$ref": "../../common/schema.json#/$defs/HumanDuration"
        },
        "cron": {
          "$ref": "../../common/schema.json#/$defs/Cron"
        },
        "proxy_http": {
          "$ref": "#/$defs/ProbeHttp"
        },
        "http": {
          "$ref": "#/$defs/ProbeHttp"
        },
        "failure_threshold": {
          "type": "integer",
          "minimum": 1
        },
        "recovery_threshold": {
          "type": "integer",
          "minimum": 1
        }
      },
      "dependencies": {
        "period": {
          "not": { "required": ["cron"] }
        },
        "cron": {
          "not": { "required": ["period"] }
        },
        "proxy_http": {
          "not": { "required": ["http"] }
        },
        "http": {
          "not": { "required": ["proxy_http"] }
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ProbeHttp": {
      "required": ["method", "url"],
      "properties": {
        "method": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "body_raw": {
          "type": "string"
        },
        "body_json": {
          "type": "object"
        },
        "body": {
          "type": "string"
        },
        "timeout": {
          "$ref": "../../common/schema.json#/$defs/HumanDuration"
        }
      }
    },
    "SetupFlow": {
      "type": "object",
      "properties": {
        "preconnect": {
          "$ref": "#/$defs/SetupFlowPhase"
        },
        "credentials": {
          "$ref": "#/$defs/SetupFlowPhase"
        },
        "configure": {
          "$ref": "#/$defs/SetupFlowPhase"
        }
      },
      "additionalProperties": false
    },
    "SetupFlowPhase": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/SetupFlowStep"
          }
        }
      },
      "additionalProperties": false
    },
    "SetupFlowStep": {
      "type": "object",
      "required": ["id", "json_schema"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "json_schema": {
          "type": "object"
        },
        "ui_schema": {
          "type": "object"
        },
        "data_sources": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/DataSourceDef"
          }
        },
        "if": {
          "$ref": "#/$defs/SetupFlowStepIf"
        }
      },
      "additionalProperties": false
    },
    "SetupFlowStepIf": {
      "type": "object",
      "required": ["javascript"],
      "properties": {
        "javascript": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "DataSourceDef": {
      "type": "object",
      "required": ["proxy_request", "transform"],
      "properties": {
        "proxy_request": {
          "$ref": "#/$defs/DataSourceProxyRequest"
        },
        "transform": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "DataSourceProxyRequest": {
      "type": "object",
      "required": ["method", "url"],
      "properties": {
        "method": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "id": {
      "$ref": "../../common/schema.json#/$defs/UUID"
    },
    "namespace": {
      "$ref": "../namespace/schema.json#/$defs/NamespacePath"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "version": {
      "type": "integer"
    },
    "state": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "logo": {
      "$ref": "../../common/schema.json#/$defs/Image"
    },
    "highlight": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "auth": {
      "oneOf": [
        { "$ref": "./schema-oauth.json" },
        { "$ref": "#/$defs/AuthApiKey" },
        { "$ref": "#/$defs/AuthNoAuth" }
      ]
    },
    "probes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Probe"
      }
    },
    "setup_flow": {
      "$ref": "#/$defs/SetupFlow"
    },
    "telemetry": {
      "$ref": "#/$defs/ConnectorTelemetry"
    }
  },
  "required": ["labels", "display_name", "logo", "auth"],
  "additionalProperties": false,
  "type": "object"
}
